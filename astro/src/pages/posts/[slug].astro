---
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { listPosts, cleanSlug, formatDate } from '../../lib/posts';

export const getStaticPaths = (async () => {
  const posts = await listPosts('en');
  return posts.map((entry) => ({ params: { slug: cleanSlug(entry) }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
const readingText: string | undefined = remarkPluginFrontmatter?.readingTime?.text;
const cat = entry.data.categories?.[0] ?? 'notes';
const preview = entry.data.preview;
---
<Layout
  title={`${entry.data.title} — leins275`}
  description={entry.data.description}
  lang="en"
  activeNav="blog"
  ogImage={preview?.src}
>
  <article>
    <div class="ahead">
      <div class="kick">#{cat}{readingText ? ` · ${readingText}` : ''}</div>
      <h1>{entry.data.title}</h1>
      <div class="byline">
        <span class="meta">Nikita Lanskov</span>
        <span class="meta">·</span>
        <span class="meta">{formatDate(entry.data.date, 'en')}</span>
      </div>
    </div>
    {preview && (
      <Image class="cover" src={preview} alt={entry.data.title} loading="eager" />
    )}
    <div class="body">
      <Content />
    </div>
  </article>
  <div class="artnav">
    <a href="/blog/">← All writing</a>
  </div>
</Layout>
