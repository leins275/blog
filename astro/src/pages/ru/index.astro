---
import Layout from '../../layouts/Layout.astro';
import HomeSection from '../../components/HomeSection.astro';
import { listPosts } from '../../lib/posts';

const posts = (await listPosts('ru')).slice(0, 5);
---
<Layout
  title="Никита Лансков — leins275"
  description="Заметки об инженерии, фокусе и искусстве делать меньше, но лучше."
  lang="ru"
  activeNav="home"
>
  <HomeSection lang="ru" posts={posts} />
</Layout>
